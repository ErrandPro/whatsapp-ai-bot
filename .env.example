# ─── Server ───────────────────────────────────────────
PORT=3000

# ─── Security ─────────────────────────────────────────
# Strong secret key - n8n uses this to send messages back
API_KEY=change-this-to-a-strong-secret

# ─── n8n Webhook ──────────────────────────────────────
# Paste your n8n webhook URL here after setting up n8n
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/whatsapp

# ─── Allowed Contacts (optional) ──────────────────────
# Comma-separated phone numbers (with country code, no +)
# Leave empty to allow ALL contacts
# Example: 256700000000,256711111111
ALLOWED_CONTACTS=

# ─── Auth Folder ──────────────────────────────────────
# Where WhatsApp session is stored
AUTH_FOLDER=/tmp/auth_info
